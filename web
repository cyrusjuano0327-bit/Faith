let currentFilter = 'all';

function renderCards(filter) {
  const grid = document.getElementById('essaysGrid');
  const filtered = filter === 'all' ? essays : essays.filter(e => e.category === filter);
  grid.innerHTML = filtered.map(e => `
    <div class="essay-card" onclick="openModal('${e.id}')">
      <div class="card-category">${e.categoryLabel}</div>
      <h3 class="card-title">${e.title}</h3>
      <p class="card-excerpt">${e.excerpt}</p>
      <div class="card-meta">${e.date} &nbsp;·&nbsp; Click to read</div>
    </div>
  `).join('');
}

function filterEssays(filter, btn) {
  currentFilter = filter;
  document.querySelectorAll('.topic-pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  renderCards(filter);
}

function openModal(id) {
  const essay = essays.find(e => e.id === id);
  if (!essay) return;
  document.getElementById('modalCategory').textContent = essay.categoryLabel;
  document.getElementById('modalTitle').textContent = essay.title;
  document.getElementById('modalMeta').textContent = essay.date;
  document.getElementById('modalBody').innerHTML = essay.body;
  document.getElementById('modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

function handleContact() {
  alert('Thank you for your message. Pax Christi.');
}


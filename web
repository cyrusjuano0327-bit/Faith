    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(201,168,76,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 80%, rgba(92,26,26,0.4) 0%, transparent 60%);
  }

  .cross-decoration {
    font-size: 2rem;
    color: var(--gold);
    opacity: 0.7;
    margin-bottom: 2rem;
    animation: fadeDown 1.2s ease forwards;
    letter-spacing: 0.5em;
  }

  .hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 600;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: 0.5rem;
    animation: fadeDown 1.4s ease forwards;
    position: relative;
  }

  .hero-subtitle {
    font-family: 'IM Fell English', serif;
    font-style: italic;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: var(--gold-light);
    opacity: 0.85;
    margin-bottom: 2.5rem;
    animation: fadeDown 1.6s ease forwards;
    letter-spacing: 0.05em;
  }

  .hero-divider {
    width: 120px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 0 auto 2.5rem;
    animation: fadeIn 2s ease forwards;
  }

  .hero-intro {
    max-width: 580px;
    color: rgba(245,240,232,0.75);
    font-size: 1.1rem;
    line-height: 1.8;
    font-style: italic;
    animation: fadeUp 1.8s ease forwards;
    position: relative;
  }

  .hero-cta {
    margin-top: 3rem;
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    justify-content: center;
    animation: fadeUp 2s ease forwards;
    position: relative;
  }

  .btn {
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.85rem 2.2rem;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--deep-burgundy);
  }
  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(201,168,76,0.25);
  }

  .btn-secondary {
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold);
  }
  .btn-secondary:hover {
    background: rgba(201,168,76,0.1);
    transform: translateY(-2px);
  }

  /* ── SAINT QUOTE BANNER ── */
  .quote-banner {
    background: var(--deep-burgundy);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 3.5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .quote-banner::before {
    content: '\201C';
    position: absolute;
    top: -1rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Cormorant Garamond', serif;
    font-size: 10rem;
    color: rgba(201,168,76,0.07);
    line-height: 1;
    pointer-events: none;
  }

  .quote-text {
    font-family: 'IM Fell English', serif;
    font-style: italic;
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    color: var(--cream);
    max-width: 700px;
    margin: 0 auto 1.2rem;
    line-height: 1.6;
    position: relative;
  }

  .quote-attribution {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
  }

  /* ── SECTIONS ── */
  section { padding: 5rem 2rem; }

  .container {
    max-width: 1080px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 80px;
  }

  .section-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 400;
    color: var(--deep-burgundy);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  /* ── FEATURED ESSAY ── */
  .featured {
    background: var(--parchment);
    border-top: 3px solid var(--gold);
    padding: 5rem 2rem;
  }

  .featured-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .featured-tag {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    background: var(--deep-burgundy);
    display: inline-block;
    padding: 0.3rem 0.9rem;
    margin-bottom: 1.2rem;
  }

  .featured-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 400;
    color: var(--deep-burgundy);
    line-height: 1.25;
    margin-bottom: 1.2rem;
  }

  .featured-excerpt {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.85;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .featured-ornament {
    font-size: 8rem;
    line-height: 1;
    color: var(--gold);
    opacity: 0.12;
    font-family: 'Cinzel', serif;
    text-align: right;
    user-select: none;
  }

  /* ── ESSAY GRID ── */
  .essays-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .essay-card {
    background: white;
    border: 1px solid rgba(201,168,76,0.2);
    padding: 2rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .essay-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: var(--gold);
    transition: height 0.3s ease;
  }

  .essay-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(92,26,26,0.1); }
  .essay-card:hover::before { height: 100%; }

  .card-category {
    font-family: 'Cinzel', serif;
    font-size: 0.62rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }

  .card-title {
    font-family: 'Cinzel', serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--deep-burgundy);
    line-height: 1.4;
    margin-bottom: 0.8rem;
  }

  .card-excerpt {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    font-style: italic;
  }

  .card-meta {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* ── ABOUT ── */
  .about {
    background: var(--deep-burgundy);
    color: var(--cream);
  }

  .about-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .about .section-title { color: var(--cream); }

  .about-text {
    font-size: 1.1rem;
    line-height: 1.9;
    color: rgba(245,240,232,0.8);
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .about-signature {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
    margin-top: 2rem;
  }

  /* ── TOPICS ── */
  .topics-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .topic-pill {
    font-family: 'Cinzel', serif;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    border: 1px solid var(--border);
    color: var(--deep-burgundy);
    cursor: pointer;
    transition: all 0.25s;
    background: white;
  }

  .topic-pill:hover, .topic-pill.active {
    background: var(--deep-burgundy);
    color: var(--gold);
    border-color: var(--deep-burgundy);
  }

  /* ── ESSAY MODAL ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,5,5,0.85);
    z-index: 200;
    align-items: flex-start;
    justify-content: center;
    padding: 2rem 1rem;
    overflow-y: auto;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--cream);
    max-width: 740px;
    width: 100%;
    padding: 4rem;
    position: relative;
    margin: auto;
    animation: fadeUp 0.4s ease;
  }

  .modal-close {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    background: none; border: none;
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--deep-burgundy); }

  .modal-category {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .modal-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--deep-burgundy);
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .modal-meta {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .modal-body {
    font-size: 1.1rem;
    line-height: 1.95;
    color: #2a1f10;
  }

  .modal-body p { margin-bottom: 1.5rem; }
  .modal-body p:first-child::first-letter {
    font-family: 'Cinzel', serif;
    font-size: 4rem;
    font-weight: 600;
    float: left;
    line-height: 0.8;
    margin: 0.1em 0.1em 0 0;
    color: var(--deep-burgundy);
  }

  /* ── CONTACT ── */
  .contact {
    background: var(--parchment);
    text-align: center;
  }

  .contact-form {
    max-width: 540px;
    margin: 3rem auto 0;
  }

  .form-group {
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .form-label {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--deep-burgundy);
    display: block;
    margin-bottom: 0.5rem;
  }

  .form-input {
    width: 100%;
    padding: 0.9rem 1.2rem;
    background: white;
    border: 1px solid rgba(92,26,26,0.2);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s;
  }
  .form-input:focus { border-color: var(--gold); }

  textarea.form-input { min-height: 130px; resize: vertical; }

  /* ── FOOTER ── */
  footer {
    background: #0d0505;
    color: rgba(245,240,232,0.5);
    text-align: center;
    padding: 3rem 2rem;
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  footer .footer-cross {
    font-size: 1.5rem;
    color: var(--gold);
    opacity: 0.5;
    margin-bottom: 1.2rem;
    display: block;
    letter-spacing: 0.4em;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .featured-inner { grid-template-columns: 1fr; gap: 2rem; }
    .featured-ornament { display: none; }
    .modal { padding: 2.5rem 1.5rem; }
    .nav-links { gap: 1.2rem; }
    .nav-links a { font-size: 0.65rem; }
  }
</style>
</head>
<body>

<!-- NAVIGATION -->
<nav>
  <a href="#home" class="nav-brand">✝ Sub Tuum Praesidium</a>
  <ul class="nav-links">
    <li><a href="#essays">Essays</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="cross-decoration">✦ ✝ ✦</div>
  <h1 class="hero-title">Reflections on the<br>Catholic Faith</h1>
  <p class="hero-subtitle">Written in the light of Tradition</p>
  <div class="hero-divider"></div>
  <p class="hero-intro">
    A quiet corner of the web devoted to exploring the inexhaustible riches of the Catholic faith — 
    through Marian theology, the sacramental life, Sacred Scripture, and the witness of the saints.
  </p>
  <div class="hero-cta">
    <a href="#essays" class="btn btn-primary">Read the Essays</a>
    <a href="#about" class="btn btn-secondary">About This Site</a>
  </div>
</section>

<!-- SAINT QUOTE -->
<div class="quote-banner">
  <p class="quote-text" id="quoteText">
    "You have made us for yourself, O Lord, and our heart is restless until it rests in you."
  </p>
  <p class="quote-attribution" id="quoteAuthor">— St. Augustine of Hippo, Confessions</p>
</div>

<!-- FEATURED ESSAY -->
<section class="featured" id="featured">
  <div class="featured-inner">
    <div>
      <span class="featured-tag">Featured Essay</span>
      <h2 class="featured-title">Mary, Mediatrix of All Grace: The Logic of the Incarnation</h2>
      <p class="featured-excerpt">
        If God chose to enter the world through a human mother, this was no mere biological necessity 
        but a theological statement of the highest order. In Mary, God reveals that He works 
        through secondary causes — and invites our cooperation in the work of salvation.
      </p>
      <a href="#" class="btn btn-primary" onclick="openModal('marian'); return false;">Read Essay</a>
    </div>
    <div class="featured-ornament">✝</div>
  </div>
</section>

<!-- ESSAYS -->
<section id="essays" style="background: var(--cream);">
  <div class="container">
    <div class="section-label">Essays</div>
    <h2 class="section-title">Browse by Topic</h2>

    <div class="topics-grid">
      <button class="topic-pill active" onclick="filterEssays('all', this)">All</button>
      <button class="topic-pill" onclick="filterEssays('marian', this)">Marian Theology</button>
      <button class="topic-pill" onclick="filterEssays('prayer', this)">Prayer & Devotion</button>
      <button class="topic-pill" onclick="filterEssays('sacraments', this)">The Sacraments</button>
      <button class="topic-pill" onclick="filterEssays('saints', this)">The Saints</button>
      <button class="topic-pill" onclick="filterEssays('scripture', this)">Sacred Scripture</button>
    </div>

    <div class="essays-grid" id="essaysGrid">
      <!-- Cards injected by JS -->
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="about-inner">
    <div class="section-label" style="justify-content:center; color: var(--gold);">About</div>
    <h2 class="section-title">Why These Essays</h2>
    <p class="about-text">
      Faith seeks understanding — fides quaerens intellectum, in the words of St. Anselm. These essays 
      are an attempt to take that maxim seriously: to sit with the mysteries of the Catholic faith not 
      merely as doctrines to be accepted, but as living truths to be explored, wondered at, and shared.
    </p>
    <p class="about-text">
      Drawn to the tradition through the writings of the saints — de Montfort, Kolbe, Aquinas, Augustine — 
      and nourished by the sacramental life of the Church, I write as a student, not a theologian. 
      Every essay is an act of gratitude for a faith that never stops giving.
    </p>
    <p class="about-signature">✝ Written for the glory of God and the honor of Our Lady</p>
  </div>
</section>

<!-- CONTACT -->
<section class="contact" id="contact">
  <div class="container">
    <div class="section-label" style="justify-content:center;">Contact</div>
    <h2 class="section-title">Get in Touch</h2>
    <p style="color: var(--muted); font-style: italic; font-size: 1.05rem;">
      Questions, reflections, corrections? I welcome correspondence from fellow pilgrims.
    </p>
    <div class="contact-form">
      <div class="form-group">
        <label class="form-label">Your Name</label>
        <input type="text" class="form-input" placeholder="John or Jane">
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-input" placeholder="your@email.com">
      </div>
      <div class="form-group">
        <label class="form-label">Message</label>
        <textarea class="form-input" placeholder="Write your message here..."></textarea>
      </div>
      <button class="btn btn-primary" style="width:100%;" onclick="handleContact()">Send Message</button>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <span class="footer-cross">✦ ✝ ✦</span>
  <p>Sub Tuum Praesidium &nbsp;·&nbsp; All essays written for the greater glory of God</p>
  <p style="margin-top:0.8rem; opacity:0.5;">A.M.D.G. &nbsp;·&nbsp; Ad Majorem Dei Gloriam</p>
</footer>

<!-- ESSAY MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕ Close</button>
    <div class="modal-category" id="modalCategory"></div>
    <h2 class="modal-title" id="modalTitle"></h2>
    <div class="modal-meta" id="modalMeta"></div>
    <div class="modal-body" id="modalBody"></div>
  </div>
</div>

<script>
const essays = [
  {
    id: 'marian',
    category: 'marian',
    categoryLabel: 'Marian Theology',
    title: 'Mary, Mediatrix of All Grace: The Logic of the Incarnation',
    date: 'May 2025',
    excerpt: 'If God chose to enter the world through a human mother, this was no mere biological necessity but a theological statement of highest order.',
    body: `<p>If God chose to enter the world through a human mother, this was no mere biological necessity but a theological statement of the highest order. In Mary, God reveals that He works through secondary causes — and invites our cooperation in the work of salvation.</p>
    <p>St. Louis de Montfort understood this with characteristic depth. In his <em>True Devotion to Mary</em>, he argues that just as God willed to depend on Mary for His first coming into the world, so He wills to depend on her for His coming into souls. This is not a diminishment of divine sovereignty but its most paradoxical expression: God glorifies Himself by glorifying His creature.</p>
    <p>The objection is familiar: why go to Mary when we can go directly to Christ? But this misunderstands the nature of mediation. All grace comes from the Father, through the Son, in the Holy Spirit. Mary's mediation is always subordinate and derivative — she mediates only what she has first received. As the Second Vatican Council teaches in <em>Lumen Gentium</em>, her maternal mediation in no way obscures the unique mediation of Christ but rather demonstrates its fruitfulness.</p>
    <p>To pray through Mary is not to bypass Christ but to walk the very path He walked — the path of flesh, of creaturely dependence, of loving surrender to the Father's will. In honoring the mother, we are led ever deeper into the mystery of the Son.</p>`
